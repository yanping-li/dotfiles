#!/bin/bash

# Fix SSH auth socket location so agent forwarding works with tmux.
# Creates a stable symlink that tmux.conf references via:
#   set-environment -g SSH_AUTH_SOCK ~/.ssh/ssh_auth_sock

if [ -S "$SSH_AUTH_SOCK" ] ; then
    HOST=$(hostname)

    PERSONAL_LAPTOP=("yanpingli-mbp")
    PAN_LAPTOP=("M-MPJ9Q5FX4K")
    PAN_SERVER=("congo" "danube" "euphrates" "ganges" "indus" "irrawaddy"
                "amur" "kolyma" "ishim" "japura" "volga" "yukon"
                "zambezi" "aldan" "tunguska" "ural" "salween" "mekong")

    ALL_HOSTS=("${PERSONAL_LAPTOP[@]}" "${PAN_LAPTOP[@]}" "${PAN_SERVER[@]}")

    if [[ " ${ALL_HOSTS[@]} " =~ " $HOST " ]]; then
        ln -sf $SSH_AUTH_SOCK ~/.ssh/ssh_auth_sock
    fi
fi
